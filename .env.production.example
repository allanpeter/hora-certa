# === PRODUCTION ENVIRONMENT ===

# Database
DATABASE_URL=postgresql://user:password@prod-db-host:5432/hora_certa_prod

# Server
NODE_ENV=production
PORT=3001
API_URL=https://api.horacerta.com

# JWT
JWT_SECRET=change-to-secure-random-secret-in-production
JWT_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=production-google-client-id
GOOGLE_CLIENT_SECRET=production-google-client-secret
GOOGLE_CALLBACK_URL=https://api.horacerta.com/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=production-apple-client-id
APPLE_TEAM_ID=production-apple-team-id
APPLE_KEY_ID=production-apple-key-id
APPLE_PRIVATE_KEY=production-apple-private-key
APPLE_CALLBACK_URL=https://api.horacerta.com/auth/apple/callback

# AbakatePay
ABAKATE_PAY_API_KEY=production-abakate-pay-api-key
ABAKATE_PAY_API_SECRET=production-abakate-pay-api-secret
ABAKATE_PAY_WEBHOOK_SECRET=production-abakate-pay-webhook-secret
ABAKATE_PAY_SANDBOX=false

# Email Service
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=production-sendgrid-api-key
EMAIL_FROM=noreply@horacerta.com

# WhatsApp
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=production-twilio-account-sid
TWILIO_AUTH_TOKEN=production-twilio-auth-token
TWILIO_PHONE_NUMBER=+5511999999999

# Logging
LOG_LEVEL=error

# Redis
REDIS_URL=redis://redis-host:6379
