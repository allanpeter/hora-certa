# Frontend Production Environment
# This file is used by Vite during build (npm run build)

# API URL (optional - defaults to /api, which Nginx will proxy)
# Nginx will route /api/* to backend:3001/* automatically
# VITE_API_URL=/api

# Or if using separate domain:
# VITE_API_URL=https://api.horacerta.com

# Other variables
VITE_APP_NAME=Hora Certa
