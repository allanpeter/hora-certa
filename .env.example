# === BACKEND CONFIGURATION ===

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/hora_certa_dev
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=hora_certa_dev

# Server
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key
APPLE_CALLBACK_URL=http://localhost:3001/api/auth/apple/callback

# AbakatePay (Payment Provider)
ABAKATE_PAY_API_KEY=your-abakate-pay-api-key
ABAKATE_PAY_API_SECRET=your-abakate-pay-api-secret
ABAKATE_PAY_WEBHOOK_SECRET=your-abakate-pay-webhook-secret
ABAKATE_PAY_SANDBOX=true

# Email Service
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@horacerta.com

# WhatsApp (Phase 2)
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Logging
LOG_LEVEL=debug

# Redis (optional, for caching/sessions)
REDIS_URL=redis://localhost:6379

# === FRONTEND CONFIGURATION ===

# API
REACT_APP_API_URL=http://localhost:3001
REACT_APP_ENVIRONMENT=development

# Google OAuth
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id

# Apple OAuth
REACT_APP_APPLE_CLIENT_ID=your-apple-client-id
